        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Work3"
        mc:Ignorable="d"
        Title="Подключение" ResizeMode="NoResize" Height="150" Width="220">
    <Grid Width="200" Margin="10,0,10,0">
        <TextBox x:Name="Text_HostName" HorizontalAlignment="Center" Margin="0,41,0,0" VerticalAlignment="Top" Width="160.4" Text="localhost"/>
        <Label Content="Имя хоста" HorizontalAlignment="Left" Margin="20,10,0,0" VerticalAlignment="Top"/>
        <Button x:Name="Button_Connect" Content="Подключится" HorizontalAlignment="Left" Margin="100,72,0,0" VerticalAlignment="Top" Width="80" Click="Button_Connect_Click"/>

    </Grid>
</Window>

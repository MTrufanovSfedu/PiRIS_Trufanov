<Window x:Class="Work3.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Work3"
        mc:Ignorable="d"
        Title="Авторизация" ResizeMode="NoResize" Height="200" Width="220">
    <Grid Height="180" Width="200">
        <TextBox x:Name="Text_UserName" HorizontalAlignment="Center" Margin="0,41,0,0" VerticalAlignment="Top" Width="160.4" TextChanged="Text_UserName_TextChanged"/>
        <Label Content="Имя пользователя" HorizontalAlignment="Left" Margin="20,10,0,0" VerticalAlignment="Top"/>
        <Label Content="Пароль" HorizontalAlignment="Left" Margin="20,64,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="Text_Password" HorizontalAlignment="Center" Margin="0,95,0,0" VerticalAlignment="Top" Width="160.4" TextChanged="Text_Password_TextChanged"/>
        <Button x:Name="button_sign_in" Content="Войти" HorizontalAlignment="Left" Margin="108,124,0,0" VerticalAlignment="Top" Width="72.4" Click="button_sign_in_Click" IsEnabled="False"/>
        <Button x:Name="button_sign_up" Content="Регистрация" HorizontalAlignment="Left" Margin="20,124,0,0" VerticalAlignment="Top" Width="72.4" Click="Button_Click"/>

    </Grid>
</Window>

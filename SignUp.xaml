<Window x:Class="Work3.SignUp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Work3"
        mc:Ignorable="d"
        Title="Регистрация" ResizeMode="NoResize" Width="220" Height="280">
    <Grid Height="240" Width="200">
        <TextBox HorizontalAlignment="Center" Margin="0,41,0,0" VerticalAlignment="Top" Width="160.4"/>
        <Label Content="Имя пользователя" HorizontalAlignment="Left" Margin="20,10,0,0" VerticalAlignment="Top"/>
        <Label Content="Пароль" HorizontalAlignment="Left" Margin="20,64,0,0" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Center" Margin="0,95,0,0" VerticalAlignment="Top" Width="160.4"/>
        <Button Content="Создать аккаунт" HorizontalAlignment="Left" Margin="88,192,0,0" VerticalAlignment="Top" Width="92" IsEnabled="False"/>
        <Button x:Name="button_sign_in" Content="Вход" HorizontalAlignment="Left" Margin="20,192,0,0" VerticalAlignment="Top" Width="52" Click="button_sign_in_Click"/>
        <Label Content="Повторить пароль" HorizontalAlignment="Left" Margin="20,118,0,0" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Center" Margin="0,149,0,0" VerticalAlignment="Top" Width="160"/>

    </Grid>
</Window>
